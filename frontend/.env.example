EXPO_PUBLIC_API_BASE_URL=http://YOUR_LOCAL_IP:5000
EXPO_PUBLIC_API_URL=http://YOUR_LOCAL_IP:5000
EXPO_PUBLIC_CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
EXPO_PUBLIC_CLOUDINARY_UPLOAD_PRESET=your_cloudinary_upload_preset
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
EXPO_PUBLIC_PROJECT_ID=your_expo_project_id

# ── Location / Venue Search APIs ──────────────────────────────────────────────
# Controls which provider is active: 'mappls' (India-optimised, default) | 'google'
EXPO_PUBLIC_LOCATION_PROVIDER=mappls

# Google Maps Places API (New) — Demo key for development
# Upgrade to a billing-enabled key for production
# Get your key at: https://console.cloud.google.com/apis/library/places-backend.googleapis.com
EXPO_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Mappls (MapmyIndia) — Free developer tier
# Register at: https://apis.mappls.com/console
EXPO_PUBLIC_MAPPLS_CLIENT_ID=your_mappls_client_id_here
EXPO_PUBLIC_MAPPLS_CLIENT_SECRET=your_mappls_client_secret_here
