# SnooSpace Backend — Environment Variables
# Copy this file to .env and fill in the actual values

# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=postgres
DB_PASS=your_postgres_password
DB_NAME=snoospace

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key
SUPABASE_ANON_KEY=your_supabase_anon_key

# ─── Cloudinary ───────────────────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ─── Razorpay ─────────────────────────────────────────────────────────────────
# Get Key ID and Key Secret from: Razorpay Dashboard → Settings → API Keys
# Use test keys (rzp_test_...) for development
# Use live keys (rzp_live_...) for production — NEVER commit live keys
RAZORPAY_KEY_ID=rzp_test_xxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Webhook Secret is a string YOU define in: Razorpay Dashboard → Settings → Webhooks
# It is SEPARATE from the Key Secret. Use a strong random string (min 32 chars)
# Example: openssl rand -hex 32
RAZORPAY_WEBHOOK_SECRET=your_strong_random_webhook_secret

# ─── Upstash Redis ────────────────────────────────────────────────────────────
# Used by the "People You Should Meet" recommendation engine for caching.
# Get these from: Upstash Console → your database → REST API tab
UPSTASH_REDIS_REST_URL=https://your-database-name.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_rest_token

# ─── Recommendations (optional overrides) ────────────────────────────────────
# These are handled via config/recommendationConfig.js (no restart-free tuning yet).
# Documented here so ops can find the lever; edit the config file to change values.
# RECS_ACTIVE_WITHIN_DAYS=21
# RECS_CANDIDATE_POOL_LIMIT=300
# RECS_DISMISSAL_COOLDOWN_DAYS=14

